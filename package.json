{
  "name": "convert-vscode-extension",
  "displayName": "convert_vscode_extension",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:convertView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "convert-vscode-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "convertView.removeFile",
        "title": "Remove",
        "icon": "$(close)"
      },
      {
        "command": "convertView.clearFiles",
        "title": "Clear All",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "convertView.clearFiles",
          "when": "view == convertView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "convertView.removeFile",
          "when": "view == convertView",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "convertSidebar",
          "title": "Convert VSCode Extension",
          "icon": "$(star)"
        }
      ]
    },
    "views": {
      "convertSidebar": [
        {
          "id": "convertDropZone",
          "name": "Drop Files Here",
          "type": "tree"
        },
        {
          "id": "convertView",
          "name": "Convert",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
