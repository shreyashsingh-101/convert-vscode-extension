{
  "name": "convert-vscode-extension",
  "displayName": "Convert VSCode Extension",
  "description": "Upload JS/CSS files to Convert.com variations",
  "version": "0.0.2",
  "publisher": "ShreyashSingh101",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "resources/icon.png",
  "categories": ["Other"],
  "repository": {
    "type": "git",
    "url": "https://github.com/shreyashsingh-101/convert-vscode-extension"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "convert-panel",
          "title": "Convert VSCode Extension",
          "icon": "/resources/icon.svg"
        }
      ]
    },
    "views": {
      "convert-panel": [
        {
          "id": "convertDropZone",
          "name": "Files Drop Zone",
          "type": "tree",
          "icon": "/resources/icon.svg"
        },
        {
          "id": "convertSidebar",
          "name": "CVE",
          "type": "webview",
          "icon": "/resources/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}